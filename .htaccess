RewriteEngine On
Options ALL -Indexes
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([^.]+)$ $1.html [NC,L]

RewriteRule (^|/)assets(/|$) - [F]

<Files .htaccess>
Order allow,deny
Deny from all
</Files>

<Files README.md>
Order allow,deny
Deny from all
</Files>

<Files LICENSE>
Order allow,deny
Deny from all
</Files>
