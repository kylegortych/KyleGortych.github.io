RewriteEngine On
#Options ALL -Indexes
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([^.]+)$ $1.html [NC,L]

RewriteRule ^.*/assets/.*$ - [R=403]
RewriteRule ^.*/.htaccess - [R=403]
RewriteRule ^.*/README.md - [R=403]
RewriteRule ^.*/LICENSE - [R=403]

# <Files .htaccess>
# Order allow,deny
# Deny from all
# </Files>
