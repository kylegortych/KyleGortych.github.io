RewriteEngine On
Options All -Indexes
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([^.]+)$ $1.html [NC,L]

<Files ./README.md ./LICENSE>
  Order allow,deny
  Deny from all
</FilesMatch>

<FilesMatch "^\.">
  Order allow,deny
  Deny from all
</FilesMatch>

<Directory ~ "\assets">
  Order allow,deny
  Deny from all
</Directory>
